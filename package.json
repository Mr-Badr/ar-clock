{
  "name": "ar-clock",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run events:build",
    "dev": "next dev",
    "prebuild": "npm run events:build",
    "export-fallback": "sh -c 'if [ -f .env.local ]; then tsx --env-file=.env.local scripts/export-fallback.ts; else tsx scripts/export-fallback.ts; fi'",
    "build": "npm run export-fallback && next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx",
    "typecheck": "tsc --noEmit",
    "test:unit": "tsx --test tests/*.test.ts",
    "events:migrate-packages": "tsx --env-file=.env.local scripts/migrate-events-to-packages.ts",
    "events:migrate-data": "tsx --env-file=.env.local scripts/migrate-events-to-data-folders.ts",
    "events:build": "tsx scripts/generate-events-index.ts",
    "events:generate-index": "npm run events:build",
    "events:new": "tsx --env-file=.env.local scripts/events-new.ts",
    "events:apply-batch": "node --import tsx scripts/events-apply-batch.ts",
    "events:autofill": "node --import tsx scripts/events-autofill.ts --write",
    "events:fix-related": "node --import tsx scripts/events-fix-related.ts --write",
    "events:normalize-copy": "node --import tsx scripts/events-normalize-copy.ts --write",
    "events:clean-tier1": "node --import tsx scripts/events-clean-tier1.ts --write",
    "events:publish": "tsx --env-file=.env.local scripts/events-publish.ts",
    "contentops:scaffold": "tsx --env-file=.env.local scripts/generate-content-ops-scaffold.ts",
    "events:sync": "npm run events:build && npm run contentops:scaffold",
    "validate:holidays": "tsx --env-file=.env.local scripts/validate-holiday-content.ts",
    "validate:holidays:strict": "tsx --env-file=.env.local scripts/validate-holiday-content.ts --strict",
    "validate:holidays:slug": "tsx --env-file=.env.local scripts/validate-holiday-content.ts --strict",
    "validate:holidays:changed": "tsx --env-file=.env.local scripts/validate-holiday-content.ts --strict --changed --json",
    "validate:holidays:tier1": "tsx --env-file=.env.local scripts/validate-holiday-content.ts --strict --tier=tier1 --json",
    "build:smoke": "next build",
    "ci:check": "npm run lint && npm run typecheck && npm run test:unit && npm run validate:holidays"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@internationalized/date": "^3.12.0",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-accordion": "^1.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.3",
    "@radix-ui/react-aspect-ratio": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-context-menu": "^2.2.3",
    "@radix-ui/react-dialog": "^1.1.3",
    "@radix-ui/react-dropdown-menu": "^2.1.3",
    "@radix-ui/react-hover-card": "^1.1.3",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-menubar": "^1.1.3",
    "@radix-ui/react-navigation-menu": "^1.2.2",
    "@radix-ui/react-popover": "^1.1.3",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.2",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.3",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.3",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-toggle-group": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@sparticuz/chromium": "^143.0.4",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "25.2.1",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "adhan": "^4.4.3",
    "autoprefixer": "10.4.24",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cobe": "^0.6.5",
    "critters": "^0.0.25",
    "date-fns": "^3.6.0",
    "embla-carousel-react": "^8.5.2",
    "eslint": "9.39.2",
    "eslint-config-next": "16.1.6",
    "input-otp": "^1.4.1",
    "lucide-react": "^0.468.0",
    "luxon": "^3.7.2",
    "motion": "^12.38.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "postcss": "8.5.6",
    "puppeteer": "^24.39.1",
    "puppeteer-core": "^24.39.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.4.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.2",
    "react-resizable-panels": "^2.1.8",
    "recharts": "^2.15.0",
    "sonner": "^1.7.3",
    "svg-dotted-map": "^2.1.0",
    "tailwind-merge": "^2.6.1",
    "tailwindcss": "4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.9.3",
    "vaul": "^1.1.2",
    "zod": "^3.24.1"
  },
  "overrides": {
    "react-is": "19.0.0"
  },
  "devDependencies": {
    "babel-plugin-react-compiler": "^1.0.0",
    "postgres": "^3.4.8",
    "shadcn": "^3.8.4",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0"
  }
}
