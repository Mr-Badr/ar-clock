NODE_ENV=production

# Canonical public domain used for metadata, canonicals, sitemap URLs, and
# internal absolute URL building. In production this must be the real public
# domain, not a staging host.
NEXT_PUBLIC_SITE_URL=https://miqatona.com
NEXT_PUBLIC_BASE_URL=https://miqatona.com

# Required by the `/api/revalidate` route and validated in production mode.
# Always set this. Generate with:
#   openssl rand -hex 32
REVALIDATE_SECRET=replace-with-long-random-secret

# Optional. Used for Google Search Console site verification. Usually set in
# production.
GOOGLE_SITE_VERIFICATION=

# Runtime geo provider switch.
#
# Current safe production posture while production still uses Supabase:
# ENABLE_LIVE_GEO_DB=false
# LIVE_GEO_PROVIDER=supabase
#
# Future self-hosted production posture after the real PostgreSQL cutover:
# ENABLE_LIVE_GEO_DB=true
# LIVE_GEO_PROVIDER=postgres
#
# In `postgres` mode, the app runtime does not require the Supabase variables
# below. Keep them only if you still run legacy migration/export scripts.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key

# Optional admin key for one-off scripts and privileged Supabase operations.
# Keep empty unless you explicitly need it.
SUPABASE_SERVICE_ROLE_KEY=
ENABLE_LIVE_GEO_DB=false
LIVE_GEO_PROVIDER=supabase

# Container image settings.
#
# APP_IMAGE must match the image path your CI/CD actually publishes to.
# A clean convention is:
#   ghcr.io/<github-owner-or-org>/ar-clock
# If this app becomes part of a GitHub organization, using the org namespace is
# usually more professional than keeping a personal username in production.
APP_IMAGE=ghcr.io/mr-badr/ar-clock

# Production tag. You can keep a stable tag like `production`, or switch to
# immutable release tags / git SHAs if your deployment flow supports that.
APP_TAG=production

# Keep `standalone` for Docker deployments. This matches the repo's Next.js
# container build.
NEXT_OUTPUT_MODE=standalone

# Optional version label exposed in runtime diagnostics such as `/api/health`.
APP_VERSION=2026.04.29-1

# Production Nginx host and indexing rules.
# `all` allows normal indexing. Do not use the staging noindex value here.
NGINX_SERVER_NAME=miqatona.com www.miqatona.com
NGINX_CANONICAL_HOST=miqatona.com
NGINX_X_ROBOTS_TAG=all

# Keep this on a high localhost port while staging and production coexist on the
# same VPS. Switch to 80 only when VPS production becomes the public origin.
NGINX_HTTP_PORT=8082

# Economy pages still work without provider keys. `auto` is the recommended
# default. Add keys only if you want richer live data.
ECONOMY_LIVE_DATA_PROVIDER=auto
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
FRED_API_KEY=
NEWSAPI_API_KEY=
GNEWS_API_KEY=

# IP lookup base URL used for optional coarse geo lookup from client IP.
IP_API_BASE_URL=http://ip-api.com

# Keep PDF generation off unless you intentionally want the PDF calendar route
# available in production and have verified VPS capacity for headless Chromium.
ENABLE_PDF_CALENDAR=false

# Keep `bundled` on the VPS unless you are deploying to a serverless platform.
PDF_BROWSER_MODE=bundled

# Analytics and ads.
#
# Production recommendation:
# - analytics: off until tracking is truly ready
# - ads: off until monetization is truly ready
# - consent banner: on only if your analytics/ads setup requires it
ENABLE_ANALYTICS=false
GA_MEASUREMENT_ID=
GTM_ID=
ENABLE_CONSENT_BANNER=false

# Service worker / PWA support. Safe default is off until you intentionally
# test and support caching/offline behavior in production.
ENABLE_SW=false

# Leave empty to disable ads globally. Set only when you are ready to run
# AdSense on the live site.
ADSENSE_CLIENT_ID=
ADS_TXT_EXTRA_LINES=

# Future PostgreSQL phase only. Inside Docker, the app should use the internal
# Postgres service hostname. Prisma CLI on the host should use localhost.
DATABASE_URL=
PRISMA_DATABASE_URL=
POSTGRES_DB=miqatona_production
POSTGRES_USER=miqatona
POSTGRES_PASSWORD=change-me
POSTGRES_HOST_PORT=5434

# Optional feature flags. Safe to leave commented unless you are intentionally
# rolling out or testing a branch feature.
# FF_HOLIDAYS_NEW_METADATA=true
# FF_HOLIDAYS_CONTENT_RESOLVER=true
# FF_HOLIDAYS_SECTIONIZED_UI=false
# FF_SEO_STRICT_CLEANUP=true
# FF_OBSERVABILITY_LOGS=false
# FF_EVENTS_SHARD_INDEX=true
# FF_EVENTS_PUBLISHED_ONLY=true
# ENABLE_NEW_PRAYER_ENGINE=false
