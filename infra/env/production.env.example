############################
# APP
############################
NODE_ENV=production

APP_IMAGE=ghcr.io/mr-badr/ar-clock
APP_TAG=production
NEXT_OUTPUT_MODE=standalone
APP_VERSION=production

############################
# PUBLIC DOMAINS
############################
NEXT_PUBLIC_SITE_URL=https://miqatona.com
NEXT_PUBLIC_BASE_URL=https://miqatona.com

############################
# SECURITY
############################
REVALIDATE_SECRET=replace-with-long-random-secret
GOOGLE_SITE_VERIFICATION=

############################
# GEO (POSTGRES ONLY)
############################
ENABLE_LIVE_GEO_DB=true
LIVE_GEO_PROVIDER=postgres

############################
# NGINX
############################
NGINX_SERVER_NAME=miqatona.com www.miqatona.com
NGINX_CANONICAL_HOST=miqatona.com
NGINX_X_ROBOTS_TAG=all
NGINX_HTTP_PORT=8082

############################
# POSTGRES
############################
POSTGRES_DB=miqatona_production
POSTGRES_USER=miqatona
POSTGRES_PASSWORD=change-me
POSTGRES_HOST_PORT=5434

DATABASE_URL=postgresql://miqatona:change-me@postgres:5432/miqatona_production
PRISMA_DATABASE_URL=postgresql://miqatona:change-me@127.0.0.1:5434/miqatona_production

############################
# ANALYTICS
############################
NEXT_PUBLIC_ENABLE_ANALYTICS=true
GA_MEASUREMENT_ID=
GTM_ID=

############################
# ADS
############################
NEXT_PUBLIC_ENABLE_ADS=false
ADSENSE_CLIENT_ID=

############################
# SYSTEM
############################
ENABLE_CONSENT_BANNER=false
ENABLE_SW=false
IP_API_BASE_URL=http://ip-api.com
ENABLE_PDF_CALENDAR=false
PDF_BROWSER_MODE=bundled
