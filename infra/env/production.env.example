# =============================================================================
# Miqatona production environment
# Target path on VPS: /opt/miqatona/env/production.env
# =============================================================================
#
# Replace every CHANGE_ME value before deployment.
# Keep this file out of the running container if it still contains placeholders.
#

############################
# CORE
############################

NODE_ENV=production

# Set this to the deployed release or Git SHA so /api/health identifies the
# actual image. Example: 2026.06.13-prod-1 or git-abc1234.
APP_VERSION=CHANGE_ME_RELEASE_ID

# Compose image selection. APP_TAG must identify the image verified on staging.
APP_IMAGE=ghcr.io/mr-badr/ar-clock
APP_TAG=prod

# Canonical production origin. Keep both values identical and without a
# trailing slash.
NEXT_PUBLIC_SITE_URL=https://miqatona.com
NEXT_PUBLIC_BASE_URL=https://miqatona.com

# Optional when Search Console ownership is already verified by DNS.
GOOGLE_SITE_VERIFICATION=

############################
# SECURITY
############################

# Use a long, unique random value. This protects the revalidation endpoint.
REVALIDATE_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

############################
# POSTGRES
############################

POSTGRES_DB=miqatona_prod
POSTGRES_USER=miqatona
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD

# Keep the password synchronized with POSTGRES_PASSWORD and URL-encode any
# reserved URL characters. The hostname must match the production Postgres
# service/container name on the Docker network.
DATABASE_URL=postgresql://miqatona:CHANGE_ME_DATABASE_PASSWORD@miqatona-prod-postgres:5432/miqatona_prod

############################
# GEO DATA
############################

# Recommended for the first Ads launch: false. Public country/city pages use the
# bundled validated snapshot, removing Postgres from their critical render path.
# Set true only when production geo rows are actively maintained and Postgres
# health has been verified; the code still retains snapshot fallbacks.
ENABLE_LIVE_GEO_DB=false
LIVE_GEO_PROVIDER=postgres

# Keep false unless a paid/commercial HTTPS IP-geolocation provider is configured
# and its privacy/retention terms have been reviewed. Browser timezone and
# country hints continue to work while this is false.
ENABLE_IP_GEO_LOOKUP=false
IP_API_BASE_URL=

############################
# PDF CALENDAR
############################

# Keep false unless downloadable PDF calendars are intentionally launched and
# Chromium memory usage has been tested on the VPS.
ENABLE_PDF_CALENDAR=false
PDF_BROWSER_MODE=bundled

############################
# ANALYTICS
############################

# Recommended during AdSense review: false. To enable later, configure exactly
# one tracking route (GA4 directly or GTM), implement the required consent flow,
# test it in EEA/UK/Switzerland, then change this to true.
ENABLE_ANALYTICS=false
GA_MEASUREMENT_ID=
GTM_ID=

# This is the app's first-party preference banner, not proof of a
# Google-certified CMP. Keep false when using Google's Privacy & messaging CMP.
# Set true only if this local banner is intentionally used to gate analytics.
ENABLE_CONSENT_BANNER=false

############################
# ADSENSE
############################

# Public publisher account ID. It is safe to store in source/runtime config.
# Keeping it configured does not load ads while the certified CMP flag is false.
ADSENSE_CLIENT_ID=ca-pub-5421885011942418

# Keep false during site verification and review. First configure and publish a
# Google-certified CMP message in AdSense Privacy & messaging (or another
# certified TCF CMP), verify the live consent flow, then set this to true.
# Ad scripts and placements cannot load while this remains false.
GOOGLE_CERTIFIED_CMP_ENABLED=false

# Leave empty unless another authorized seller line is intentionally required.
# Confirm the Docker Compose env-file syntax before adding multiline values.
ADS_TXT_EXTRA_LINES=

############################
# SERVICE WORKER
############################

# Keep false for launch to avoid stale HTML/assets. Enable only after offline
# caching behavior has been tested across deployments and rollbacks.
ENABLE_SW=false

############################
# STABLE FEATURE FLAGS
############################

# These values preserve the currently validated production behavior.
FF_HOLIDAYS_NEW_METADATA=true
FF_HOLIDAYS_CONTENT_RESOLVER=true
FF_HOLIDAYS_SECTIONIZED_UI=false
FF_SEO_STRICT_CLEANUP=true
FF_OBSERVABILITY_LOGS=false
FF_EVENTS_SHARD_INDEX=true
FF_EVENTS_PUBLISHED_ONLY=true
ENABLE_NEW_PRAYER_ENGINE=false
