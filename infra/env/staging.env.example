NODE_ENV=production

# Public staging URL used for metadata, canonicals, sitemap URLs, and internal
# absolute URL building. Keep this as the real staging host. Do not point it at
# production.
NEXT_PUBLIC_SITE_URL=https://staging.miqatona.com
NEXT_PUBLIC_BASE_URL=https://staging.miqatona.com

# Required by the `/api/revalidate` route and validated in production mode.
# Always set this in staging and production. Generate with:
#   openssl rand -hex 32
REVALIDATE_SECRET=replace-with-long-random-secret

# Optional. Used only if you want to verify this environment in Google Search
# Console. Usually empty in staging, usually set in production.
GOOGLE_SITE_VERIFICATION=

# Runtime geo provider switch.
#
# Safe first boot if staging still depends on Supabase:
# ENABLE_LIVE_GEO_DB=false
# LIVE_GEO_PROVIDER=supabase
#
# After you import geo data into local Docker Postgres, staging can switch to:
# ENABLE_LIVE_GEO_DB=true
# LIVE_GEO_PROVIDER=postgres
#
# In `postgres` mode, the app runtime does not require the Supabase variables
# below. Keep them only if you still run legacy migration/export scripts.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key

# Optional admin key for one-off scripts and privileged Supabase operations.
# Keep empty unless you explicitly need it.
SUPABASE_SERVICE_ROLE_KEY=
ENABLE_LIVE_GEO_DB=false
LIVE_GEO_PROVIDER=supabase

# Container image settings.
#
# APP_IMAGE must match the image path your CI/CD actually publishes to.
# Keeping the image name aligned with the GitHub repo name is the cleanest
# convention. Example:
#   ghcr.io/<github-owner-or-org>/ar-clock
# If you later move the repo to a GitHub organization, prefer the org namespace
# over a personal username for a more production-style setup.
APP_IMAGE=ghcr.io/mr-badr/ar-clock

# Docker image tag for this environment. Common values: `staging`, `production`,
# or a git SHA / release tag if your pipeline publishes immutable builds.
APP_TAG=staging

# Keep `standalone` for Docker deployments. This matches the repo's Next.js
# container build.
NEXT_OUTPUT_MODE=standalone

# Optional version label exposed in runtime diagnostics such as `/api/health`.
# Useful for confirming what build is deployed.
APP_VERSION=2026.04.29-1

# Nginx host and indexing rules for staging.
# Staging should stay noindex so search engines do not index it.
NGINX_SERVER_NAME=staging.miqatona.com
NGINX_CANONICAL_HOST=staging.miqatona.com
NGINX_X_ROBOTS_TAG=noindex, nofollow, noarchive

# Host-side Nginx port used by the stack on the VPS. Keep a high port in
# staging, such as 8081, instead of binding staging directly as the public
# origin.
NGINX_HTTP_PORT=8081

# App runtime inside Docker uses the internal service hostname `postgres`.
# Prisma CLI on the VPS host uses 127.0.0.1:${POSTGRES_HOST_PORT}.
POSTGRES_DB=miqatona_staging
POSTGRES_USER=miqatona

# Real database password for the Docker Postgres container.
# Replace with a strong secret before real usage.
POSTGRES_PASSWORD=change-me

# Host-mapped Postgres port for VPS shell tools such as Prisma or psql.
POSTGRES_HOST_PORT=5433

# Used by the app container at runtime. Inside Docker, the hostname must remain
# `postgres`, not `127.0.0.1`.
DATABASE_URL=postgresql://miqatona:change-me@postgres:5432/miqatona_staging

# Used by Prisma CLI when run from the VPS shell. From the host machine,
# localhost/127.0.0.1 must be used instead of the Docker service hostname.
PRISMA_DATABASE_URL=postgresql://miqatona:change-me@127.0.0.1:5433/miqatona_staging

# Economy pages still work without provider keys. `auto` is the recommended
# setting in staging and production. Add keys only if you want richer live data.
ECONOMY_LIVE_DATA_PROVIDER=auto
ALPHA_VANTAGE_API_KEY=
TWELVE_DATA_API_KEY=
FRED_API_KEY=
NEWSAPI_API_KEY=
GNEWS_API_KEY=

# IP lookup base URL used for optional coarse geo lookup from client IP.
# Keep the default unless you replace the provider yourself.
IP_API_BASE_URL=http://ip-api.com

# Keep PDF generation off unless you explicitly need the PDF calendar route.
# On smaller VPS machines, leaving this off is the safer default.
ENABLE_PDF_CALENDAR=false

# Keep `bundled` on the VPS unless you are deploying to a serverless platform.
PDF_BROWSER_MODE=bundled

# Analytics and ads.
#
# Staging recommendation:
# - keep analytics off
# - keep ads off
# - keep consent banner off unless you specifically test it
ENABLE_ANALYTICS=false
GA_MEASUREMENT_ID=
GTM_ID=

# Turn on only when analytics or ads are enabled and your legal setup requires
# user consent before loading marketing scripts.
ENABLE_CONSENT_BANNER=false

# Service worker / PWA support. Safe default is off in staging unless you are
# specifically testing offline/PWA behavior.
ENABLE_SW=false

# Leave empty to disable ads globally.
ADSENSE_CLIENT_ID=

# Optional extra lines for `/ads.txt`. Usually empty until monetization is live.
ADS_TXT_EXTRA_LINES=

# Optional feature flags. Safe to leave commented unless you are intentionally
# testing a branch feature.
# FF_HOLIDAYS_NEW_METADATA=true
# FF_HOLIDAYS_CONTENT_RESOLVER=true
# FF_HOLIDAYS_SECTIONIZED_UI=false
# FF_SEO_STRICT_CLEANUP=true
# FF_OBSERVABILITY_LOGS=false
# FF_EVENTS_SHARD_INDEX=true
# FF_EVENTS_PUBLISHED_ONLY=true
# ENABLE_NEW_PRAYER_ENGINE=false
