NODE_ENV=production

# Public staging URL. Replace this with the real staging host once DNS is live.
NEXT_PUBLIC_SITE_URL=https://staging.miqatona.com
NEXT_PUBLIC_BASE_URL=https://staging.miqatona.com

# Required in production-mode Next.js runtime
REVALIDATE_SECRET=replace-with-long-random-secret
GOOGLE_SITE_VERIFICATION=

# Current application behavior still expects Supabase-compatible runtime envs.
# Keep these set until the query layer is migrated to direct PostgreSQL.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=
ENABLE_LIVE_GEO_DB=false
LIVE_GEO_PROVIDER=supabase

# Shared image/build settings
APP_IMAGE=ghcr.io/mr-badr/ar-clock
APP_TAG=staging
NEXT_OUTPUT_MODE=standalone

# Staging Nginx
NGINX_SERVER_NAME=staging.miqatona.com
NGINX_CANONICAL_HOST=staging.miqatona.com
NGINX_X_ROBOTS_TAG=noindex, nofollow, noarchive
NGINX_HTTP_PORT=8081

# Local PostgreSQL target used for migration rehearsal and backup import tests.
POSTGRES_DB=miqatona_staging
POSTGRES_USER=miqatona
POSTGRES_PASSWORD=change-me
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgresql://miqatona:change-me@postgres:5432/miqatona_staging

# Optional runtime flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ADS=false
NEXT_PUBLIC_ENABLE_CONSENT_BANNER=false
