NODE_ENV=development

# Local canonical URL for metadata and internal URL building.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Required by the revalidation route. Use a throwaway local value.
REVALIDATE_SECRET=dev_secret_change_me

# Current application runtime still expects Supabase-compatible envs.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key

# Optional. Only needed for admin scripts or privileged server operations.
SUPABASE_SERVICE_ROLE_KEY=

# Keep the live geo bridge in its safe current mode until the Postgres query
# layer is implemented.
ENABLE_LIVE_GEO_DB=false
LIVE_GEO_PROVIDER=supabase

# Optional local feature flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ADS=false
NEXT_PUBLIC_ENABLE_CONSENT_BANNER=false
