# =============================================================================
# miqatona.com — Environment Variables (VPS / PostgreSQL)
# =============================================================================
# Copy this file to .env.local for local development.
# On the Hetzner VPS, variables are set in infra/env/.env.production
#
# ⚠️  Supabase is NO LONGER USED. Do NOT add Supabase keys.
# ⚠️  The app runs entirely on PostgreSQL (Prisma + Docker).
# =============================================================================

NODE_ENV=development
APP_VERSION=dev

# ── Site URL ─────────────────────────────────────────────────────────────────
# Local canonical URL for metadata and internal URL building.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Security ──────────────────────────────────────────────────────────────────
# Required by the revalidation route. Use a throwaway local value.
REVALIDATE_SECRET=dev_secret_change_me

# ── Database (PostgreSQL only) ────────────────────────────────────────────────
# Local development: run Postgres via Docker on your Mac.
#   docker run -d --name miqatona-pg \
#     -e POSTGRES_USER=miqatona \
#     -e POSTGRES_PASSWORD=localpassword \
#     -e POSTGRES_DB=miqatona_local \
#     -p 5432:5432 postgres:16-alpine
DATABASE_URL=postgresql://miqatona:localpassword@127.0.0.1:5432/miqatona_local
PRISMA_DATABASE_URL=postgresql://miqatona:localpassword@127.0.0.1:5432/miqatona_local

# ── Geo DB ────────────────────────────────────────────────────────────────────
# Set to true only when local Postgres has the imported geo data.
# LIVE_GEO_PROVIDER is always 'postgres' on VPS (no Supabase).
ENABLE_LIVE_GEO_DB=false
LIVE_GEO_PROVIDER=postgres

# ── IP Geo Lookup ─────────────────────────────────────────────────────────────
# Free tier: http://ip-api.com (45 req/min, no HTTPS)
# Paid tier: https://pro.ip-api.com (faster, HTTPS, higher limits)
IP_API_BASE_URL=http://ip-api.com

# ── Analytics ────────────────────────────────────────────────────────────────
# Use GTM or GA4 directly. @vercel/analytics is NOT used on VPS.
ENABLE_ANALYTICS=false
# GA_MEASUREMENT_ID=G-XXXXXXXXXX
# GTM_ID=GTM-XXXXXXX
ENABLE_CONSENT_BANNER=false

# ── PWA / Service Worker ─────────────────────────────────────────────────────
ENABLE_SW=false

# ── Ads ───────────────────────────────────────────────────────────────────────
# Ads are disabled when this is empty.
# Manual placements live in src/lib/ads/manual-config.js.
ADSENSE_CLIENT_ID=
