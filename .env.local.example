NODE_ENV=development
APP_VERSION=2026.04.29-1

# Local canonical URL for metadata and internal URL building.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Required by the revalidation route. Use a throwaway local value.
REVALIDATE_SECRET=dev_secret_change_me

# Safe local default:
# ENABLE_LIVE_GEO_DB=false
# LIVE_GEO_PROVIDER=supabase
#
# If you run the geo database locally with Docker and want the app to read from
# Postgres instead:
# ENABLE_LIVE_GEO_DB=true
# LIVE_GEO_PROVIDER=postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key

# Optional. Only needed for admin scripts or privileged server operations.
SUPABASE_SERVICE_ROLE_KEY=

# Safe local default. Switch these to `true` + `postgres` only when your local
# Docker Postgres has the imported geo data.
ENABLE_LIVE_GEO_DB=false
LIVE_GEO_PROVIDER=supabase

# Local app runtime and Prisma CLI can both use localhost when Postgres is
# published directly from Docker on your machine.
DATABASE_URL=postgresql://miqatona:startaymz1598753@127.0.0.1:5432/miqatona_local
PRISMA_DATABASE_URL=postgresql://miqatona:startaymz1598753@127.0.0.1:5432/miqatona_local

# Optional local feature flags
ENABLE_ANALYTICS=false
ENABLE_CONSENT_BANNER=false
ENABLE_SW=false

# Ads are disabled by default when the client id is empty.
# Add ADSENSE_CLIENT_ID once and Google Auto Ads can start globally.
# Manual placements live in src/lib/ads/manual-config.js.
ADSENSE_CLIENT_ID=
