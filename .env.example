NODE_ENV=production

# Public canonical domain used in metadata, canonicals, structured data, and sitemaps.
# Keep both values identical in production.
# On Vercel, set these to your final custom domain once connected, e.g. https://miqatona.com
NEXT_PUBLIC_SITE_URL=https://miqatona.com
NEXT_PUBLIC_BASE_URL=https://miqatona.com

# Google Search Console verification token
# Example: google1234567890abcdef
GOOGLE_SITE_VERIFICATION=replace-with-google-search-console-token

# On-demand revalidation secret
# Use a long random string. This protects /api/revalidate.
REVALIDATE_SECRET=startaymz1598753

# Supabase credentials used by the live app
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key

# Optional public aliases kept for browser-side code and compatibility
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-supabase-anon-key

# Optional script-only database helpers
# Used by scripts/createTables.js when you need direct Postgres access.
SUPABASE_DB_URL=
SUPABASE_DB_PASSWORD=

# Optional infrastructure/runtime overrides
# Usually leave these unset unless you explicitly need them.
IP_API_BASE_URL=http://ip-api.com
PDF_BROWSER_MODE=
NEXT_PUBLIC_ENABLE_SW=true
ENABLE_LIVE_GEO_DB=false
LIVE_GEO_PROVIDER=supabase

# Optional Docker / VPS bridge settings
# These do not change the current Vercel + Supabase runtime unless you choose
# to use them for a standalone container build later.
NEXT_OUTPUT_MODE=
HOSTNAME=0.0.0.0
PORT=3000

# Optional future direct Postgres settings for the VPS migration.
# They are documented here now, but the live app still keeps Supabase as the
# active data backend until you explicitly migrate the query layer.
DATABASE_URL=
POSTGRES_DB=miqatona
POSTGRES_USER=miqatona
POSTGRES_PASSWORD=change-me

# Vercel system environment variables
# These are injected automatically by Vercel and do not need manual local values.
# They are listed here for documentation because runtime URL resolution can use them.
VERCEL_PROJECT_PRODUCTION_URL=
VERCEL_URL=

# Analytics and tag management placeholders
# These are optional and stay inactive until you explicitly enable them.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-N25LF6BM0K
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Ads and monetization placeholders
# The ad UI components already exist in the codebase and stay hidden until
# you enable ads and provide real AdSense identifiers.
NEXT_PUBLIC_ENABLE_ADS=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_TOP_BANNER_SLOT=
NEXT_PUBLIC_ADSENSE_IN_ARTICLE_SLOT=
NEXT_PUBLIC_ADSENSE_STICKY_ANCHOR_SLOT=
NEXT_PUBLIC_ADSENSE_SIDEBAR_SLOT=
NEXT_PUBLIC_ADSENSE_SIDEBAR_RIGHT_SLOT=
NEXT_PUBLIC_ADSENSE_SIDEBAR_LEFT_SLOT=
ADSENSE_CLIENT_ID=
ADS_TXT_EXTRA_LINES=

# Consent / compliance placeholder
# Recommended before enabling analytics or ads in markets that require consent.
NEXT_PUBLIC_ENABLE_CONSENT_BANNER=false

# Feature flags
# FF_HOLIDAYS_NEW_METADATA:
#   true = use the unified metadata pipeline for /holidays/[slug]
#   false = keep legacy behavior
FF_HOLIDAYS_NEW_METADATA=true

# FF_HOLIDAYS_CONTENT_RESOLVER:
#   true = use the new JSON-first holiday content resolver
#   false = fallback to older content pipeline behavior
FF_HOLIDAYS_CONTENT_RESOLVER=true

# FF_HOLIDAYS_SECTIONIZED_UI:
#   true = enable the newer sectionized holiday details UI
#   false = keep the simpler stable layout
FF_HOLIDAYS_SECTIONIZED_UI=false

# FF_SEO_STRICT_CLEANUP:
#   true = keep stricter cleanup and validation rules enabled
#   false = relax SEO cleanup behavior for debugging only
FF_SEO_STRICT_CLEANUP=true

# FF_OBSERVABILITY_LOGS:
#   true = print extra observability/debug logs on the server
#   false = quieter production logging
FF_OBSERVABILITY_LOGS=false

# FF_EVENTS_SHARD_INDEX:
#   true = use generated JSON shard/index files for faster event reads
#   false = disable the shard/index optimization
FF_EVENTS_SHARD_INDEX=true

# FF_EVENTS_PUBLISHED_ONLY:
#   true = only published/approved events appear in runtime listings and holiday sitemap
#   false = include all canonical events, including drafts
FF_EVENTS_PUBLISHED_ONLY=true
